{
  "manifest_version": 3,
  "name": "Affiliate Auditor: The Merchant's Shield",
  "version": "1.0.0",
  "description": "Detects and proves affiliate hijacking and coupon scraping by browser extensions like Honey.",
  "permissions": [
    "cookies",
    "webNavigation",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
